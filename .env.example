# Backend Environment Variables for Render
# Copy these into Render Dashboard → Environment Variables

# CORS - Set this to your Vercel frontend URL after deployment
# Example: CORS_ALLOWED_ORIGINS=https://parksense-app.vercel.app
CORS_ALLOWED_ORIGINS=*

# Optional: If you need a Groq API key for GenAI Analyst
# GROQ_API_KEY=your_groq_key_here
